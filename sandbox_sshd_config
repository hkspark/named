# Default settings
Port 22
Protocol 2

# Allow admin normal shell access
Match User cyberrange
    X11Forwarding yes
    AllowTcpForwarding yes
    PermitTTY yes

# Apply sandbox (restricted shell) to everyone else
Match all
    ForceCommand /usr/bin/rbash
    ChrootDirectory /home/%u
    AllowTcpForwarding no
    X11Forwarding no
    PermitTTY yes


